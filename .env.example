PORT=3003

JWT_SECRET=replace-with-a-long-random-secret

# SSH Key Encryption (for system SSH key management)
# Must be at least 32 characters - can be plain text or hex
SSH_KEY_ENCRYPTION_SECRET=replace-with-a-secure-encryption-secret-min-32-chars

# Database
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# SMTP / Mail server
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cookie configuration - must include dot prefix to work across subdomains
COOKIE_DOMAIN=.example.com
NODE_ENV=production

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://example.com/api/auth/google/callback
FRONTEND_URL=https://example.com
# Admin frontend URL (when user logs in as admin through Google OAuth)
FRONTEND_URL_ADMIN=https://admin.example.com

# Sepay webhook (signed bank transaction notifications)
SEPAY_WEBHOOK_API_KEY=

# Bank account shown on the payment QR / instructions screen
BANK_ACCOUNT_NUMBER=
BANK_NAME=
